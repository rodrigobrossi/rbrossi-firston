# ============================================================
# FirstOn CRM — Environment Variables
# This file lives at the REPO ROOT alongside docker-compose.yml
#
# On first run, start.sh copies this to .env automatically.
# Never commit .env to git.
# ============================================================

# ── OAuth2: Google ──────────────────────────────────────────
# https://console.cloud.google.com → APIs → OAuth 2.0 Credentials
# Redirect URI: http://localhost:8080/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── OAuth2: Microsoft ───────────────────────────────────────
# https://portal.azure.com → App registrations
# Redirect URI: http://localhost:8080/auth/microsoft/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── PIX: Efí Bank (sandbox by default) ─────────────────────
# https://dev.efipay.com.br → My Apps
EFI_CLIENT_ID=
EFI_CLIENT_SECRET=

# ── WhatsApp: 360dialog ─────────────────────────────────────
# https://hub.360dialog.com → API Keys
# Leave empty to simulate locally (messages logged to console)
WABA_360DIALOG_API_KEY=
